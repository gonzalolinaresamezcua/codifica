# Codifica — variables de entorno

# Carpeta principal (padre de /codifica). Default: directorio padre de codifica
CODIFICA_ROOT=

# JSON DB y código generado (default: {CODIFICA_ROOT}/datos y /proyecto)
CODIFICA_DATOS_ROOT=
CODIFICA_PROYECTO_ROOT=

# Cursor SDK
CURSOR_API_KEY=
CODIFICA_MODEL_ID=composer-2.5
CODIFICA_MAX_PARALLEL=3

# Servidor HTTP
PORT=3000
