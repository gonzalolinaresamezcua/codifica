{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": [
    "agents/**/*.ts",
    "orchestrator/**/*.ts",
    "sdk/**/*.ts",
    "prompts/**/*.ts",
    "index.ts",
    "server.ts"
  ],
  "exclude": ["node_modules", "dist", "ui"]
}
